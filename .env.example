# ── Database (OPTIONAL — Prisma is retained but unused by the app) ────────────
# The app runs without a database. These are only needed if you run Prisma CLI
# commands (migrate/studio) against the local Docker Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5437/prediction_ui
DIRECT_URL=postgresql://postgres:postgres@localhost:5437/prediction_ui

# ── LP demo sealed cookies ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Required on Vercel: LP sessions are encrypted into the httpOnly cookie (not
# server memory), so AUTH_SECRET must be set and stable across deploys.
AUTH_SECRET=

# ── Privy (embedded wallet) ───────────────────────────────────────────────────
# App ID from https://dashboard.privy.io (or resolved via builder API below)
NEXT_PUBLIC_PRIVY_APP_ID=

# ── prediction-gateway (HTTP + WebSocket to prediction-go) ───────────────────
NEXT_PUBLIC_PREDICTION_GATEWAY_URL=http://localhost:2040

# ── LP demo — direct prediction-go (bypasses gateway) ─────────────────────────
# Auth uses session X-LP-Api-Key + X-LP-Address (no APP_API_KEY on this path).
# Server-side upstreams used by /api/lp/* (defaults match local prediction-go).
GAMMA_API_URL=http://localhost:8084
CLOB_API_URL=http://localhost:8083
RELAYER_API_URL=http://localhost:8085
DPM_API_URL=http://localhost:8086
DATA_API_URL=http://localhost:8091
PRICE_SERVICE_URL=http://localhost:8093
PUBLIC_WS_URL=http://localhost:8090
USER_WS_URL=http://localhost:8088

# From POST /builders (pk_builder_...); login + Privy app ID resolution
NEXT_PUBLIC_BUILDER_API_PUBLIC_KEY=

# ── Blockchain network ─────────────────────────────────────────────────────────
# Polygon Amoy testnet (80002) or Polygon mainnet (137)
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology
