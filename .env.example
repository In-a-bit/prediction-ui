# ── Database ──────────────────────────────────────────────────────────────────
# Prisma reads .env; Next.js reads .env.local
# For local dev, both files should have the same DATABASE_URL / DIRECT_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5437/prediction_ui
DIRECT_URL=postgresql://postgres:postgres@localhost:5437/prediction_ui

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Magic.link ────────────────────────────────────────────────────────────────
# Get from https://dashboard.magic.link → your app → API Keys
# Publishable key only — never put the secret key here
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_

# ── Prediction-go HTTP (browser → Next proxy → backends) ─────────────────────
# Same value as prediction-go APP_API_KEY; never expose in NEXT_PUBLIC_*.
APP_API_KEY=dev-app-api-key

# Optional server-only upstream overrides (defaults match NEXT_PUBLIC_* below).
# GAMMA_API_URL=http://localhost:8084
# CLOB_API_URL=http://localhost:8083
# RELAYER_API_URL=http://localhost:8085
# DPM_API_URL=http://localhost:8086
# DATA_API_URL=http://localhost:8091

# WebSocket proxy targets (server.js only; APP_API_KEY added as X-API-Key). Defaults from NEXT_PUBLIC_* WS URLs.
# USER_WS_UPSTREAM=http://127.0.0.1:8088
# PUBLIC_WS_UPSTREAM=http://127.0.0.1:8090

# ── Gamma API (prediction-go backend) ─────────────────────────────────────────
NEXT_PUBLIC_GAMMA_API_URL=http://localhost:8084
# From POST /builders (pk_builder_...); login + Magic publishable key resolution
NEXT_PUBLIC_BUILDER_API_PUBLIC_KEY=

# ── DPM API (collateral balance) ──────────────────────────────────────────────
NEXT_PUBLIC_DPM_API_URL=http://localhost:8086

# ── CLOB API and WebSocket ────────────────────────────────────────────────────
# Use `npm run dev` / `npm start` (server.js). Plain `next dev` does not proxy WebSockets.
NEXT_PUBLIC_CLOB_API_URL=http://localhost:8083
NEXT_PUBLIC_USER_WS_URL=ws://localhost:8088
# Base ws URL is fine — MarketWS appends /ws/market (prediction-go public-ws).
NEXT_PUBLIC_PUBLIC_WS_URL=ws://localhost:8090

# ── Blockchain network ─────────────────────────────────────────────────────────
# Polygon Amoy testnet (80002) or Polygon mainnet (137)
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology

# ── Relayer API (PROXY approval: USDC → CTF via Magic) ─────────────────────────
# Base URL: GET /contract-info (deployment addresses), GET /relay-payload, POST /submit (cookie session).
# Contract addresses are not configured in the UI; `dpm-sdk` loads them from /contract-info on attach.
NEXT_PUBLIC_RELAYER_API_URL=http://localhost:8085
