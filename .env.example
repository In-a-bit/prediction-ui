# ── Database ──────────────────────────────────────────────────────────────────
# Prisma reads .env; Next.js reads .env.local
# For local dev, both files should have the same DATABASE_URL / DIRECT_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5437/prediction_ui
DIRECT_URL=postgresql://postgres:postgres@localhost:5437/prediction_ui

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Magic.link ────────────────────────────────────────────────────────────────
# Get from https://dashboard.magic.link → your app → API Keys
# Publishable key only — never put the secret key here
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_

# ── prediction-go (server-side only; used by /api/go/* proxy and WS rewrites) ──
# Must match prediction-go .env APP_API_KEY. Never use NEXT_PUBLIC_ for this value.
APP_API_KEY=dev-app-api-key
CLOB_API_ORIGIN=http://127.0.0.1:8083
GAMMA_API_ORIGIN=http://127.0.0.1:8084
DPM_API_ORIGIN=http://127.0.0.1:8086
DATA_API_ORIGIN=http://127.0.0.1:8091
RELAYER_API_ORIGIN=http://127.0.0.1:8085
# Ports for WebSocket rewrites (prediction-go public-ws / user-ws)
PUBLIC_WS_PORT=8090
USER_WS_PORT=8088

# From POST /builders (pk_builder_...); login + Magic publishable key resolution
NEXT_PUBLIC_BUILDER_API_PUBLIC_KEY=

# ── Blockchain network ─────────────────────────────────────────────────────────
# Polygon Amoy testnet (80002) or Polygon mainnet (137)
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology

# ── Relayer API (PROXY approval: USDC → CTF via Magic) ─────────────────────────
# Browser uses /api/go/relayer and /api/relayer/submit; RELAYER_API_ORIGIN above is the upstream.
NEXT_PUBLIC_RELAY_HUB_ADDRESS=0xcfed328256B3b71a0C942A7FC8B560B598536b5d
NEXT_PUBLIC_PROXY_WALLET_FACTORY_ADDRESS=0x932dba5b6f07c2b614eeD8E4Ea023FC44aAB4F80
NEXT_PUBLIC_COLLATERAL_ADDRESS=0x9b4A302A548c7e313c2b74C461db7b84d3074A84
NEXT_PUBLIC_CTF_ADDRESS=0x41cf0Cc822DDA607457cc5429FeEAc62A1Fb0ec1
NEXT_PUBLIC_CTF_EXCHANGE_ADDRESS=0xF740e33A790E31745CdCaC2e173E7B4585C172F9
